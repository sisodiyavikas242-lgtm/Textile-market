<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Buyers & Sellers Portal</title>
<style>
  body { font-family: Arial, sans-serif; margin:0; padding:0; background:#f5f5f5; }
  header { background:#4CAF50; color:white; padding:15px; text-align:center; }
  nav { display:flex; justify-content:center; background:#333; }
  nav a { color:white; padding:14px 20px; text-decoration:none; text-align:center; }
  nav a:hover { background:#ddd; color:black; }
  .container { padding:20px; max-width:1200px; margin:auto; }
  .profile-card, .review-card { background:white; padding:15px; margin:15px 0; border-radius:10px; box-shadow:0 2px 5px rgba(0,0,0,0.1); }
  .profile-card img { width:80px; height:80px; border-radius:50%; object-fit:cover; }
  .profile-info { display:flex; align-items:center; gap:15px; }
  .profile-info div { flex:1; }
  .photo-gallery { display:grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap:10px; }
  .photo-gallery img { width:100%; border-radius:10px; }
  h2 { color:#333; margin-bottom:10px; }
  .views { font-size:0.9em; color:#555; }
</style>
</head>
<body>

<header>
  <h1>Buyers & Sellers Portal</h1>
</header>

<nav>
  <a href="#sellers">Sellers</a>
  <a href="#buyers">Buyers</a>
  <a href="#reviews">Reviews</a>
  <a href="#gallery">Gallery</a>
</nav>

<div class="container">

  <!-- Sellers Section -->
  <section id="sellers">
    <h2>Sellers</h2>
    <div class="profile-card">
      <div class="profile-info">
        <img src="https://via.placeholder.com/80" alt="Seller Photo">
        <div>
          <h3>Seller Name 1</h3>
          <p class="views">Profile Views: <span id="seller1-views">120</span></p>
          <p>Products Listed: 15</p>
        </div>
      </div>
    </div>
    <div class="profile-card">
      <div class="profile-info">
        <img src="https://via.placeholder.com/80" alt="Seller Photo">
        <div>
          <h3>Seller Name 2</h3>
          <p class="views">Profile Views: <span id="seller2-views">95</span></p>
          <p>Products Listed: 8</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Buyers Section -->
  <section id="buyers">
    <h2>Buyers</h2>
    <div class="profile-card">
      <div class="profile-info">
        <img src="https://via.placeholder.com/80" alt="Buyer Photo">
        <div>
          <h3>Buyer Name 1</h3>
          <p class="views">Profile Views: <span id="buyer1-views">75</span></p>
        </div>
      </div>
    </div>
    <div class="profile-card">
      <div class="profile-info">
        <img src="https://via.placeholder.com/80" alt="Buyer Photo">
        <div>
          <h3>Buyer Name 2</h3>
          <p class="views">Profile Views: <span id="buyer2-views">50</span></p>
        </div>
      </div>
    </div>
  </section>

  <!-- Reviews Section -->
  <section id="reviews">
    <h2>Reviews</h2>
    <div class="review-card">
      <p><strong>Buyer 1:</strong> Seller 1 provided excellent service!</p>
    </div>
    <div class="review-card">
      <p><strong>Buyer 2:</strong> Fast delivery and quality products. Highly recommend.</p>
    </div>
  </section>

  <!-- Photo Gallery Section -->
  <section id="gallery">
    <h2>Photo Gallery</h2>
    <div class="photo-gallery">
      <img src="https://via.placeholder.com/200x150" alt="Gallery Image 1">
      <img src="https://via.placeholder.com/200x150" alt="Gallery Image 2">
      <img src="https://via.placeholder.com/200x150" alt="Gallery Image 3">
      <img src="https://via.placeholder.com/200x150" alt="Gallery Image 4">
    </div>
  </section>

</div>

<script>
  // Simple JS to simulate profile view increment
  function incrementView(id) {
    const el = document.getElementById(id);
    el.textContent = parseInt(el.textContent) + 1;
  }

  // Example usage (increment Seller1 views every 5 seconds)
  setInterval(() => { incrementView('seller1-views'); }, 5000);
</script>

</body>
</html>